# =============================================================================
# saas-pix-bot — Variáveis de Ambiente
# Copie para .env e preencha os valores.
# Nunca commite o .env real — ele está no .gitignore.
# =============================================================================

# -----------------------------------------------------------------------------
# TELEGRAM BOT
# -----------------------------------------------------------------------------
# Token do bot (obrigatório) — obtido via @BotFather
TELEGRAM_BOT_TOKEN=

# Secret token para validar requests do webhook do Telegram (recomendado)
# Qualquer string aleatória (ex: openssl rand -hex 32)
TELEGRAM_BOT_SECRET=

# URL pública do bot para registro do webhook (ex: https://meu-bot.railway.app)
BOT_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# API INTERNA
# -----------------------------------------------------------------------------
# URL base da API (ex: https://minha-api.railway.app)
API_URL=

# -----------------------------------------------------------------------------
# REDIS — UPSTASH (OBRIGATÓRIO EM PRODUÇÃO)
# -----------------------------------------------------------------------------
# Sem Redis, sessões e timers de PIX são perdidos a cada restart do bot.
# O bot recusa iniciar em produção sem essas variáveis.
#
# Passos:
#   1. Acesse https://console.upstash.com e crie um banco Redis (plano free OK)
#   2. Na página do banco → clique em "REST API"
#   3. Copie UPSTASH_REDIS_REST_URL e UPSTASH_REDIS_REST_TOKEN abaixo
#   4. Adicione as mesmas vars no painel do Railway (serviço do bot)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# BANCO DE DADOS (API)
# -----------------------------------------------------------------------------
# URL de conexão PostgreSQL (Neon, Railway, etc.)
DATABASE_URL=

# -----------------------------------------------------------------------------
# MERCADO PAGO
# -----------------------------------------------------------------------------
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# SENTRY (OPCIONAL — monitoramento de erros)
# -----------------------------------------------------------------------------
SENTRY_DSN=

# -----------------------------------------------------------------------------
# ADMIN DASHBOARD (Vercel)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=
ADMIN_JWT_SECRET=

# -----------------------------------------------------------------------------
# CLOUDINARY (OPCIONAL — upload de mídia)
# -----------------------------------------------------------------------------
CLOUDINARY_URL=
