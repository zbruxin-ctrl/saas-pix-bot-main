// schema.prisma
// OPT #4: @@index([telegramUserId, status, pixExpiresAt]) adicionado ao model Payment
// OPT #9: metadata → colunas reais (paymentMethod, balanceUsed, pixAmount) em Payment
// FEAT #9: model AuditLog adicionado
// FEAT #2/#3: model AdminSetting adicionado
// FEAT: Coupon, CouponUse, Referral, VolumeTier adicionados
// FIX-BUILD: REFERRAL_REWARD adicionado ao WalletTransactionType
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Admin ────────────────────────────────────────────────────────────────────────────
model AdminUser {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  name         String
  role         AdminRole  @default(OPERATOR)
  isActive     Boolean    @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  auditLogs    AuditLog[]

  @@map("admin_users")
}

enum AdminRole {
  SUPERADMIN
  ADMIN
  OPERATOR
}

// ─── AuditLog ────────────────────────────────────────────────────────────────────
model AuditLog {
  id         String    @id @default(cuid())
  adminId    String
  action     String
  targetType String?
  targetId   String?
  metadata   String?   @db.Text
  ip         String?
  createdAt  DateTime  @default(now())

  admin AdminUser @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── AdminSetting ───────────────────────────────────────────────────────────────
model AdminSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("admin_settings")
}

// ─── Telegram ──────────────────────────────────────────────────────────────────────
model TelegramUser {
  id           String       @id @default(cuid())
  telegramId   String       @unique
  username     String?
  firstName    String?
  lastName     String?
  languageCode String?
  isBlocked    Boolean      @default(false)
  balance      Decimal      @default(0) @db.Decimal(10, 2)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  payments            Payment[]
  orders              Order[]
  stockReservations   StockReservation[]
  walletTransactions  WalletTransaction[]
  couponUses          CouponUse[]
  referralsGiven      Referral[]         @relation("ReferrerRelation")
  referralReceived    Referral?          @relation("ReferredRelation")

  @@map("telegram_users")
}

// ─── Produto ──────────────────────────────────────────────────────────────────────
model Product {
  id              String       @id @default(cuid())
  name            String
  description     String
  price           Decimal      @db.Decimal(10, 2)
  deliveryType    DeliveryType
  deliveryContent String
  isActive        Boolean      @default(true)
  stock           Int?
  sortOrder       Int          @default(0)
  metadata        Json?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  payments          Payment[]
  orders            Order[]
  stockReservations StockReservation[]
  stockItems        StockItem[]
  volumeTiers       VolumeTier[]

  @@map("products")
}

enum DeliveryType {
  TEXT
  LINK
  FILE_MEDIA
  ACCOUNT
}

// ─── StockItem ─────────────────────────────────────────────────────────────────────
model StockItem {
  id          String          @id @default(cuid())
  productId   String
  content     String          @db.Text
  status      StockItemStatus @default(AVAILABLE)
  reservedAt  DateTime?
  confirmedAt DateTime?
  deliveredAt DateTime?
  releasedAt  DateTime?
  paymentId   String?         @unique
  orderId     String?         @unique
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  product Product  @relation(fields: [productId], references: [id])
  payment Payment? @relation(fields: [paymentId], references: [id])
  order   Order?   @relation(fields: [orderId], references: [id])

  @@index([productId, status])
  @@index([productId, status, createdAt])
  @@map("stock_items")
}

enum StockItemStatus {
  AVAILABLE
  RESERVED
  CONFIRMED
  DELIVERED
  RELEASED
}

// ─── StockReservation ─────────────────────────────────────────────────────────────
model StockReservation {
  id             String                 @id @default(cuid())
  productId      String
  telegramUserId String
  paymentId      String?                @unique
  quantity       Int                    @default(1)
  status         StockReservationStatus @default(ACTIVE)
  expiresAt      DateTime
  confirmedAt    DateTime?
  releasedAt     DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  product      Product      @relation(fields: [productId], references: [id])
  telegramUser TelegramUser @relation(fields: [telegramUserId], references: [id])
  payment      Payment?     @relation(fields: [paymentId], references: [id])

  @@index([productId, status])
  @@index([expiresAt, status])
  @@index([telegramUserId])
  @@map("stock_reservations")
}

enum StockReservationStatus {
  ACTIVE
  CONFIRMED
  RELEASED
}

// ─── WalletTransaction ──────────────────────────────────────────────────────────────
model WalletTransaction {
  id             String                @id @default(cuid())
  telegramUserId String
  type           WalletTransactionType
  amount         Decimal               @db.Decimal(10, 2)
  description    String
  paymentId      String?
  createdAt      DateTime              @default(now())

  telegramUser TelegramUser @relation(fields: [telegramUserId], references: [id])

  @@index([telegramUserId])
  @@index([createdAt])
  @@map("wallet_transactions")
}

enum WalletTransactionType {
  DEPOSIT
  PURCHASE
  REFUND
  REFERRAL_REWARD
}

// ─── Payment ───────────────────────────────────────────────────────────────────────────
model Payment {
  id             String         @id @default(cuid())
  telegramUserId String
  productId      String?
  mercadoPagoId  String?        @unique
  amount         Decimal        @db.Decimal(10, 2)
  status         PaymentStatus  @default(PENDING)
  pixQrCode      String?        @db.Text
  pixQrCodeText  String?        @db.Text
  pixExpiresAt   DateTime?
  approvedAt     DateTime?
  cancelledAt    DateTime?
  expiredAt      DateTime?
  paymentMethod  PaymentMethod?
  balanceUsed    Decimal?       @db.Decimal(10, 2)
  pixAmount      Decimal?       @db.Decimal(10, 2)
  // Pricing fields
  couponId       String?
  discountAmount Decimal?       @db.Decimal(10, 2)
  originalAmount Decimal?       @db.Decimal(10, 2)
  metadata       Json?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  telegramUser     TelegramUser      @relation(fields: [telegramUserId], references: [id])
  product          Product?          @relation(fields: [productId], references: [id])
  coupon           Coupon?           @relation(fields: [couponId], references: [id])
  order            Order?
  stockReservation StockReservation?
  stockItem        StockItem?
  webhookEvents    WebhookEvent[]
  couponUse        CouponUse?
  referral         Referral?

  @@index([telegramUserId])
  @@index([status])
  @@index([mercadoPagoId])
  @@index([telegramUserId, status, pixExpiresAt])
  @@index([paymentMethod, status])
  @@map("payments")
}

enum PaymentMethod {
  PIX
  BALANCE
  MIXED
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  EXPIRED
  REFUNDED
}

// ─── Order ────────────────────────────────────────────────────────────────────────────
model Order {
  id             String      @id @default(cuid())
  paymentId      String      @unique
  telegramUserId String
  productId      String
  status         OrderStatus @default(PROCESSING)
  deliveredAt    DateTime?
  failedAt       DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  telegramUser  TelegramUser   @relation(fields: [telegramUserId], references: [id])
  payment       Payment        @relation(fields: [paymentId], references: [id])
  product       Product        @relation(fields: [productId], references: [id])
  deliveryLogs  DeliveryLog[]
  deliveryMedias DeliveryMedia[]
  stockItem     StockItem?

  @@index([telegramUserId])
  @@index([status])
  @@map("orders")
}

enum OrderStatus {
  PROCESSING
  DELIVERED
  FAILED
}

// ─── DeliveryLog ───────────────────────────────────────────────────────────────────
model DeliveryLog {
  id        String   @id @default(cuid())
  orderId   String
  status    String
  attempt   Int      @default(1)
  message   String?  @db.Text
  error     String?  @db.Text
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([status, createdAt])
  @@map("delivery_logs")
}

// ─── DeliveryMedia ─────────────────────────────────────────────────────────────────
model DeliveryMedia {
  id        String   @id @default(cuid())
  orderId   String
  url       String   @db.Text
  mediaType String
  caption   String?  @db.Text
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@map("delivery_medias")
}

// ─── WebhookEvent ───────────────────────────────────────────────────────────────────
model WebhookEvent {
  id          String             @id @default(cuid())
  provider    String
  eventType   String
  externalId  String
  paymentId   String?
  rawPayload  Json
  status      WebhookEventStatus @default(RECEIVED)
  error       String?            @db.Text
  processedAt DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  payment Payment? @relation(fields: [paymentId], references: [id])

  @@unique([provider, externalId, eventType])
  @@index([status])
  @@index([paymentId])
  @@index([createdAt])
  @@map("webhook_events")
}

enum WebhookEventStatus {
  RECEIVED
  PROCESSING
  PROCESSED
  IGNORED
  FAILED
}

// ─── Coupon ────────────────────────────────────────────────────────────────────────
model Coupon {
  id             String       @id @default(cuid())
  code           String       @unique
  discountType   DiscountType
  discountValue  Decimal      @db.Decimal(10, 2)
  minOrderValue  Decimal?     @db.Decimal(10, 2)
  maxUses        Int?
  usedCount      Int          @default(0)
  validUntil     DateTime?
  // JSON array de productIds; null = válido para todos os produtos
  productIds     String?      @db.Text
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  couponUses CouponUse[]
  payments   Payment[]

  @@index([code])
  @@index([isActive])
  @@map("coupons")
}

enum DiscountType {
  PERCENT
  FIXED
}

// ─── CouponUse ─────────────────────────────────────────────────────────────────────
model CouponUse {
  id             String   @id @default(cuid())
  couponId       String
  telegramUserId String
  paymentId      String   @unique
  createdAt      DateTime @default(now())

  coupon       Coupon       @relation(fields: [couponId], references: [id])
  telegramUser TelegramUser @relation(fields: [telegramUserId], references: [id])
  payment      Payment      @relation(fields: [paymentId], references: [id])

  // Um usuário só pode usar o mesmo cupom uma vez
  @@unique([couponId, telegramUserId])
  @@index([telegramUserId])
  @@map("coupon_uses")
}

// ─── Referral ──────────────────────────────────────────────────────────────────────
model Referral {
  id           String   @id @default(cuid())
  referrerId   String
  referredId   String   @unique  // cada usuário só pode ter sido indicado 1 vez
  paymentId    String?  @unique  // 1º pedido pago que ativou a recompensa
  rewardPaid   Boolean  @default(false)
  rewardAmount Decimal  @default(0) @db.Decimal(10, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  referrer TelegramUser  @relation("ReferrerRelation", fields: [referrerId], references: [id])
  referred TelegramUser  @relation("ReferredRelation", fields: [referredId], references: [id])
  payment  Payment?      @relation(fields: [paymentId], references: [id])

  @@index([referrerId])
  @@map("referrals")
}

// ─── VolumeTier ────────────────────────────────────────────────────────────────────
model VolumeTier {
  id              String   @id @default(cuid())
  // null = aplica a todos os produtos (tier global)
  productId       String?
  minQty          Int
  discountPercent Decimal  @db.Decimal(5, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  product Product? @relation(fields: [productId], references: [id])

  @@index([productId, minQty])
  @@map("volume_tiers")
}
