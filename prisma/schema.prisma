// schema.prisma — com StockItem para FIFO real por unidade
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Admin ────────────────────────────────────────────────────────────────────
model AdminUser {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  name         String
  role         AdminRole  @default(OPERATOR)
  isActive     Boolean    @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("admin_users")
}

enum AdminRole {
  SUPERADMIN
  ADMIN
  OPERATOR
}

// ─── Telegram ─────────────────────────────────────────────────────────────────
model TelegramUser {
  id           String       @id @default(cuid())
  telegramId   String       @unique
  username     String?
  firstName    String?
  lastName     String?
  languageCode String?
  isBlocked    Boolean      @default(false)
  balance      Decimal      @default(0) @db.Decimal(10, 2)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  payments            Payment[]
  orders              Order[]
  stockReservations   StockReservation[]
  walletTransactions  WalletTransaction[]

  @@map("telegram_users")
}

// ─── Produto ──────────────────────────────────────────────────────────────────
model Product {
  id              String       @id @default(cuid())
  name            String
  description     String
  price           Decimal      @db.Decimal(10, 2)
  deliveryType    DeliveryType
  deliveryContent String
  isActive        Boolean      @default(true)
  stock           Int?         // null = ilimitado; contagem bruta antes de reservas
  sortOrder       Int          @default(0)
  metadata        Json?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  payments         Payment[]
  orders           Order[]
  stockReservations StockReservation[]
  stockItems       StockItem[]

  @@map("products")
}

enum DeliveryType {
  TEXT
  LINK
  FILE_MEDIA
  ACCOUNT
}

// ─── StockItem — unidade individual de estoque (base do FIFO) ─────────────────
model StockItem {
  id          String          @id @default(cuid())
  productId   String
  content     String          @db.Text
  status      StockItemStatus @default(AVAILABLE)
  reservedAt  DateTime?
  confirmedAt DateTime?
  deliveredAt DateTime?
  releasedAt  DateTime?
  paymentId   String?         @unique
  orderId     String?         @unique
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  product  Product   @relation(fields: [productId], references: [id])
  payment  Payment?  @relation(fields: [paymentId], references: [id])
  order    Order?    @relation(fields: [orderId], references: [id])

  @@index([productId, status])
  @@index([productId, status, createdAt])
  @@map("stock_items")
}

enum StockItemStatus {
  AVAILABLE
  RESERVED
  CONFIRMED
  DELIVERED
  RELEASED
}

// ─── StockReservation ─────────────────────────────────────────────────────────
model StockReservation {
  id             String                 @id @default(cuid())
  productId      String
  telegramUserId String
  paymentId      String?                @unique
  quantity       Int                    @default(1)
  status         StockReservationStatus @default(ACTIVE)
  expiresAt      DateTime
  confirmedAt    DateTime?
  releasedAt     DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  product      Product      @relation(fields: [productId], references: [id])
  telegramUser TelegramUser @relation(fields: [telegramUserId], references: [id])
  payment      Payment?     @relation(fields: [paymentId], references: [id])

  @@index([productId, status])
  @@index([expiresAt, status])
  @@index([telegramUserId])
  @@map("stock_reservations")
}

enum StockReservationStatus {
  ACTIVE
  CONFIRMED
  RELEASED
}

// ─── WalletTransaction — histórico de movimentações de saldo ─────────────────
model WalletTransaction {
  id             String                @id @default(cuid())
  telegramUserId String
  type           WalletTransactionType
  amount         Decimal               @db.Decimal(10, 2)
  description    String
  paymentId      String?
  createdAt      DateTime              @default(now())

  telegramUser TelegramUser @relation(fields: [telegramUserId], references: [id])

  @@index([telegramUserId])
  @@index([createdAt])
  @@map("wallet_transactions")
}

enum WalletTransactionType {
  DEPOSIT
  PURCHASE
  REFUND
}

// ─── Payment ──────────────────────────────────────────────────────────────────
model Payment {
  id             String        @id @default(cuid())
  telegramUserId String
  productId      String?
  mercadoPagoId  String?       @unique
  amount         Decimal       @db.Decimal(10, 2)
  status         PaymentStatus @default(PENDING)
  pixQrCode      String?       @db.Text
  pixQrCodeText  String?       @db.Text
  pixExpiresAt   DateTime?
  approvedAt     DateTime?
  cancelledAt    DateTime?
  metadata       Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  telegramUser     TelegramUser      @relation(fields: [telegramUserId], references: [id])
  product          Product?          @relation(fields: [productId], references: [id])
  order            Order?
  webhookEvents    WebhookEvent[]
  stockReservation StockReservation?
  stockItem        StockItem?

  @@index([telegramUserId])
  @@index([status])
  @@index([mercadoPagoId])
  @@index([pixExpiresAt, status])
  @@map("payments")
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  EXPIRED
  REFUNDED
}

// ─── Order ────────────────────────────────────────────────────────────────────
model Order {
  id             String      @id @default(cuid())
  paymentId      String      @unique
  telegramUserId String
  productId      String
  status         OrderStatus @default(PROCESSING)
  deliveredAt    DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  payment        Payment        @relation(fields: [paymentId], references: [id])
  telegramUser   TelegramUser   @relation(fields: [telegramUserId], references: [id])
  product        Product        @relation(fields: [productId], references: [id])
  deliveryLogs   DeliveryLog[]
  deliveryMedias DeliveryMedia[]
  stockItem      StockItem?

  @@index([telegramUserId])
  @@map("orders")
}

enum OrderStatus {
  PROCESSING
  DELIVERED
  FAILED
  CANCELLED
}

// ─── DeliveryMedia ────────────────────────────────────────────────────────────
model DeliveryMedia {
  id        String            @id @default(cuid())
  orderId   String
  url       String            @db.Text
  mediaType DeliveryMediaType
  caption   String?           @db.Text
  sortOrder Int               @default(0)
  createdAt DateTime          @default(now())

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@map("delivery_medias")
}

enum DeliveryMediaType {
  IMAGE
  VIDEO
  FILE
}

// ─── DeliveryLog ─────────────────────────────────────────────────────────────
model DeliveryLog {
  id        String            @id @default(cuid())
  orderId   String
  attempt   Int               @default(1)
  status    DeliveryLogStatus
  message   String?           @db.Text
  error     String?           @db.Text
  metadata  Json?
  createdAt DateTime          @default(now())

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@map("delivery_logs")
}

enum DeliveryLogStatus {
  SUCCESS
  FAILED
  RETRYING
}

// ─── WebhookEvent ─────────────────────────────────────────────────────────────
model WebhookEvent {
  id          String             @id @default(cuid())
  provider    String             @default("mercadopago")
  eventType   String
  externalId  String
  paymentId   String?
  rawPayload  Json
  status      WebhookEventStatus @default(RECEIVED)
  processedAt DateTime?
  error       String?            @db.Text
  createdAt   DateTime           @default(now())

  payment Payment? @relation(fields: [paymentId], references: [id])

  @@unique([provider, externalId, eventType])
  @@index([externalId])
  @@map("webhook_events")
}

enum WebhookEventStatus {
  RECEIVED
  PROCESSING
  PROCESSED
  FAILED
  IGNORED
}
